        private static readonly SolidColorBrush AccentOrange;   // #f97316
        private static readonly SolidColorBrush AccentBlue;     // #3b82f6
        private static readonly SolidColorBrush AccentPink;     // #ec4899
        private static readonly SolidColorBrush TextPrimary;    // #f8fafc
        private static readonly SolidColorBrush TextSecondary;  // #94a3b8
        private static readonly SolidColorBrush TextMuted;      // #64748b
        private static readonly SolidColorBrush BorderPrimary;  // #334155

        // Legacy brushes for backward compatibility
        private static readonly SolidColorBrush RMAActiveBackground;
        private static readonly SolidColorBrush RMAInactiveBackground;
        private static readonly SolidColorBrush PanelBackground;
        private static readonly SolidColorBrush RMAModeActiveBackground;

        // Static constructor to create and freeze brushes
        static UniversalORStrategyV12()
        {
            // V12: CSS-matched colors
            BgPrimary = new SolidColorBrush(Color.FromRgb(2, 6, 23));         // #020617
            BgPrimary.Freeze();

            BgSecondary = new SolidColorBrush(Color.FromRgb(15, 23, 42));     // #0f172a
            BgSecondary.Freeze();

            BgTertiary = new SolidColorBrush(Color.FromRgb(30, 41, 59));      // #1e293b
            BgTertiary.Freeze();

            BgHover = new SolidColorBrush(Color.FromRgb(51, 65, 85));         // #334155
            BgHover.Freeze();

            AccentCyan = new SolidColorBrush(Color.FromRgb(0, 255, 255));     // #00ffff
            AccentCyan.Freeze();

            AccentGold = new SolidColorBrush(Color.FromRgb(255, 204, 0));     // #ffcc00
            AccentGold.Freeze();

            AccentGreen = new SolidColorBrush(Color.FromRgb(34, 197, 94));    // #22c55e
            AccentGreen.Freeze();

            AccentRed = new SolidColorBrush(Color.FromRgb(239, 68, 68));      // #ef4444
            AccentRed.Freeze();

            AccentPurple = new SolidColorBrush(Color.FromRgb(168, 85, 247));  // #a855f7
            AccentPurple.Freeze();

            AccentOrange = new SolidColorBrush(Color.FromRgb(249, 115, 22));  // #f97316
            AccentOrange.Freeze();

            AccentBlue = new SolidColorBrush(Color.FromRgb(59, 130, 246));    // #3b82f6
            AccentBlue.Freeze();

            AccentPink = new SolidColorBrush(Color.FromRgb(236, 72, 153));    // #ec4899
            AccentPink.Freeze();

            TextPrimary = new SolidColorBrush(Color.FromRgb(248, 250, 252));  // #f8fafc
            TextPrimary.Freeze();

            TextSecondary = new SolidColorBrush(Color.FromRgb(148, 163, 184)); // #94a3b8
            TextSecondary.Freeze();

            TextMuted = new SolidColorBrush(Color.FromRgb(100, 116, 139));    // #64748b
            TextMuted.Freeze();

            BorderPrimary = new SolidColorBrush(Color.FromRgb(51, 65, 85));   // #334155
            BorderPrimary.Freeze();

            // Legacy brushes
            RMAActiveBackground = new SolidColorBrush(Color.FromRgb(180, 100, 20));
            RMAActiveBackground.Freeze();

            RMAInactiveBackground = new SolidColorBrush(Color.FromRgb(80, 80, 100));
            RMAInactiveBackground.Freeze();

            PanelBackground = BgSecondary;

            RMAModeActiveBackground = new SolidColorBrush(Color.FromArgb(230, 50, 30, 10));
            RMAModeActiveBackground.Freeze();
        }

