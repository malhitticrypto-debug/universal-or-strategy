        #region V12 Enums

        public enum RMAAnchorType
        {
            EMA30,
            EMA65,
            EMA200,
            ORHigh,
            ORLow
        }

        public enum TargetModeType
        {
            ATR,    // ATR multipliers (0.5x, 1.0x, etc.)
            PTS,    // Fixed points (1.0, 2.0, 4.0)
            TKS,    // Fixed ticks (4, 8, 16)
            RNG     // OR Range multipliers (0.25x, 0.5x, 1.0x)
        }

