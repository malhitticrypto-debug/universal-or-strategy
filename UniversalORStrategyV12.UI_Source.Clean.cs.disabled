        private static readonly SolidColorBrush BgPrimary;      // #020617
        private static readonly SolidColorBrush BgSecondary;    // #0f172a
        private static readonly SolidColorBrush BgTertiary;     // #1e293b
        private static readonly SolidColorBrush BgHover;        // #334155
        private static readonly SolidColorBrush AccentCyan;     // #00ffff
        private static readonly SolidColorBrush AccentGold;     // #ffcc00
