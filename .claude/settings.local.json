{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Edit(*)",
      "Write(*)",
      "Grep(*)",
      "Glob(*)",
      "LS(*)",
      "Task(*)",
      "WebSearch(*)",
      "mcp__*",
      "Skill(codex:rescue)",
      "mcp__jcodemunch__list_repos",
      "mcp__jcodemunch__plan_turn",
      "mcp__jcodemunch__search_text",
      "mcp__jcodemunch__get_file_tree",
      "mcp__jcodemunch__get_file_content"
